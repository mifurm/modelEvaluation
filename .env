# Microsoft Foundry / Azure OpenAI settings required by the eval code samples
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_DEPLOYMENT=YOUR_MODEL_DEPLOYMENT_NAME

# Optional (only if you want to make API version configurable in your own scripts)
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional (only if your MLflow tracking is not already configured by Foundry)
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=foundry-evals
